{
  "name": "ecommerce-api",
  "version": "1.0.0",
  "description": "Configuration-based ecommerce backend API - single tenant, no platform dependencies",
  "type": "module",
  "main": "dist/index.js",
  "imports": {
    "#core/*": "./dist/core/*",
    "#shared/*": "./dist/shared/*",
    "#config/*": "./dist/config/*",
    "#resources/*": "./dist/resources/*",
    "#routes/*": "./dist/routes/*",
    "#lib/*": "./dist/lib/*"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:gc": "node --expose-gc dist/index.js",
    "worker": "node dist/worker.js",
    "worker:dev": "tsx watch src/worker.ts",
    "test": "npm run test:fast && npm run test:db:app && npm run test:db:domain && npm run test:integration && npm run test:replset",
    "test:fast": "vitest --config vitest.config.ts",
    "test:db": "npm run test:db:app && npm run test:db:domain",
    "test:db:app": "vitest --config vitest.shared-db-app.config.ts",
    "test:db:domain": "vitest --config vitest.shared-db-domain.config.ts",
    "test:integration": "vitest --config vitest.integration.config.ts",
    "test:replset": "vitest --config vitest.replset.config.ts",
    "test:external": "vitest --config vitest.external.config.ts",
    "test:ui": "vitest --config vitest.config.ts --ui",
    "test:coverage": "vitest --config vitest.config.ts --coverage",
    "test:watch": "vitest --config vitest.config.ts --watch",
    "validate:env": "tsx -e \"import('./src/config/validator.ts').then(m => m.validateEnvironmentOrThrow())\"",
    "seed:categories": "tsx src/resources/catalog/categories/seed-categories.ts",
    "seed:auth": "tsx scripts/seed-auth.ts",
    "migrate:branches": "tsx scripts/migrate-branches-to-orgs.ts",
    "migrate:users": "tsx scripts/migrate-users-to-ba.ts",
    "lint": "biome check src/",
    "lint:fix": "biome check --fix src/",
    "format": "biome format --write src/",
    "knip": "knip",
    "check": "biome check src/ && knip"
  },
  "engines": {
    "node": ">=24"
  },
  "keywords": [],
  "author": "Sadman Chowdhury (Github: @siam923)",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.978.0",
    "@better-auth/mongo-adapter": "^1.6.0",
    "@classytic/arc": "^2.6.3",
    "@classytic/bd-areas": "^1.0.0",
    "@classytic/bd-logistics": "^1.0.3",
    "@classytic/flow": "^0.1.5",
    "@classytic/ledger": "^0.5.1",
    "@classytic/ledger-bd": "^0.1.1",
    "@classytic/loyalty": "^0.1.0",
    "@classytic/media-kit": "^2.1.0",
    "@classytic/mongokit": "^3.5.4",
    "@classytic/mongoose-slug-plugin": "^1.0.1",
    "@classytic/notifications": "^2.0.0",
    "@classytic/promo": "^0.1.0",
    "@classytic/revenue": "^1.1.4",
    "@classytic/revenue-manual": "^0.2.3",
    "@classytic/shared-types": "^1.0.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/under-pressure": "^9.0.3",
    "better-auth": "^1.6.0",
    "close-with-grace": "^2.4.0",
    "csv": "^6.4.1",
    "dotenv": "^17.2.3",
    "fastify": "^5.8.4",
    "fastify-raw-body": "^5.0.0",
    "http-errors": "^2.0.0",
    "mongoose": "^9.3.1",
    "mongoose-timeline-audit": "^1.0.2",
    "nodemailer": "^8.0.4",
    "pino-pretty": "^13.1.2",
    "qs": "^6.15.0",
    "sharp": "^0.34.5",
    "slugify": "^1.6.6",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/http-errors": "^2.0.5",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^8.0.0",
    "knip": "^6.3.0",
    "mongodb-memory-server": "^10.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}